apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: rtr-fabric-break-glass
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
  - kind: Group
    apiGroup: rbac.authorization.k8s.io
    name: "{{ k8s_enterprise_security_rbac_groups.break_glass }}"
{% if k8s_enterprise_security_break_glass_enabled | bool %}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: "{{ k8s_enterprise_security_break_glass_serviceaccount_name }}"
  namespace: "{{ k8s_enterprise_security_break_glass_namespace }}"
  labels:
    app.kubernetes.io/name: rtr-fabric-break-glass
    app.kubernetes.io/managed-by: ansible
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: rtr-fabric-break-glass-serviceaccount
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
  - kind: ServiceAccount
    name: "{{ k8s_enterprise_security_break_glass_serviceaccount_name }}"
    namespace: "{{ k8s_enterprise_security_break_glass_namespace }}"
{% endif %}
