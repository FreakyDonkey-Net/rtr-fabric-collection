apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: restrict-latest-tags
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: {{ k8s_enterprise_security_kyverno_policy_background | bool | lower }}
  rules:
    - name: forbid-latest-image-tags
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      validate:
        message: Images tagged latest are forbidden.
        foreach:
          - list: "request.object.spec.containers"
            deny:
              conditions:
                any:
                  - key: "{% raw %}{{ ends_with(element.image, ':latest') }}{% endraw %}"
                    operator: Equals
                    value: true
          - list: "request.object.spec.initContainers || `[]`"
            deny:
              conditions:
                any:
                  - key: "{% raw %}{{ ends_with(element.image, ':latest') }}{% endraw %}"
                    operator: Equals
                    value: true
---
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: restrict-allowed-image-registries
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: {{ k8s_enterprise_security_kyverno_policy_background | bool | lower }}
  rules:
    - name: forbid-images-outside-allowed-registries
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      validate:
        message: Images must come from the approved registries list.
        foreach:
          - list: "request.object.spec.containers"
            deny:
              conditions:
                any:
                  - key: '{% raw %}{{ regex_match(''{% endraw %}{{ k8s_enterprise_security_allowed_image_registries_regex }}{% raw %}'', element.image) }}{% endraw %}'
                    operator: Equals
                    value: false
          - list: "request.object.spec.initContainers || `[]`"
            deny:
              conditions:
                any:
                  - key: '{% raw %}{{ regex_match(''{% endraw %}{{ k8s_enterprise_security_allowed_image_registries_regex }}{% raw %}'', element.image) }}{% endraw %}'
                    operator: Equals
                    value: false
{% if k8s_enterprise_security_verify_image_signatures_enabled | bool %}
---
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: verify-signed-images
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: false
  rules:
    - name: verify-cosign-signatures
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      verifyImages:
        - imageReferences:
{% for image_reference in (k8s_enterprise_security_signed_image_references | default([])) %}
            - "{{ image_reference }}"
{% endfor %}
          required: {{ k8s_enterprise_security_verify_image_signatures_required | bool | lower }}
          mutateDigest: false
          attestors:
            - count: 1
              entries:
{% for public_key in (k8s_enterprise_security_cosign_public_keys | default([])) %}
                - keys:
                    publicKeys: |-
{{ public_key | indent(22, true) }}
{% endfor %}
{% endif %}
