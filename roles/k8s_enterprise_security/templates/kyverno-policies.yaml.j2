apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: require-owned-workload-labels
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: {{ k8s_enterprise_security_kyverno_policy_background | bool | lower }}
  rules:
    - name: require-app-and-manager-labels
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      validate:
        message: Pods must declare app.kubernetes.io/name and app.kubernetes.io/managed-by.
        pattern:
          metadata:
            labels:
              app.kubernetes.io/name: "?*"
              app.kubernetes.io/managed-by: "?*"
---
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: require-pod-requests-limits
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: {{ k8s_enterprise_security_kyverno_policy_background | bool | lower }}
  rules:
    - name: require-cpu-memory-requests-and-limits
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      validate:
        message: Pods must define CPU and memory requests and limits for all containers.
        pattern:
          spec:
            containers:
              - name: "*"
                resources:
                  requests:
                    cpu: "?*"
                    memory: "?*"
                  limits:
                    cpu: "?*"
                    memory: "?*"
            =(initContainers):
              - name: "*"
                resources:
                  requests:
                    cpu: "?*"
                    memory: "?*"
                  limits:
                    cpu: "?*"
                    memory: "?*"
---
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: require-secure-pod-security-context
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: {{ k8s_enterprise_security_kyverno_policy_background | bool | lower }}
  rules:
    - name: require-runtime-default-seccomp-and-non-root
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      validate:
        message: Pods must declare RuntimeDefault seccomp and drop privilege escalation.
        pattern:
          spec:
            securityContext:
              seccompProfile:
                type: RuntimeDefault
            containers:
              - name: "*"
                securityContext:
                  runAsNonRoot: true
                  allowPrivilegeEscalation: false
                  capabilities:
                    drop:
                      - ALL
            =(initContainers):
              - name: "*"
                securityContext:
                  runAsNonRoot: true
                  allowPrivilegeEscalation: false
                  capabilities:
                    drop:
                      - ALL
---
apiVersion: kyverno.io/v1
kind: ClusterPolicy
metadata:
  name: restrict-privileged-containers
spec:
  validationFailureAction: {{ k8s_enterprise_security_kyverno_validation_failure_action }}
  background: {{ k8s_enterprise_security_kyverno_policy_background | bool | lower }}
  rules:
    - name: forbid-privileged-containers
      match:
        any:
          - resources:
              kinds:
                - Pod
      exclude:
        any:
          - resources:
              namespaces:
{% for namespace in (k8s_enterprise_security_kyverno_policy_excluded_namespaces | default([])) %}
                - {{ namespace }}
{% endfor %}
      validate:
        message: Privileged containers are forbidden outside declared exception namespaces.
        pattern:
          spec:
            containers:
              - =(securityContext):
                  =(privileged): false
            =(initContainers):
              - =(securityContext):
                  =(privileged): false
            =(ephemeralContainers):
              - =(securityContext):
                  =(privileged): false
---
apiVersion: kyverno.io/v1
