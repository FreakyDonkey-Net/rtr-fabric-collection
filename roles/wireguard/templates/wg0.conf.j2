[Interface]
Address = {{ wireguard_address }}
ListenPort = {{ wireguard_listen_port }}
PrivateKey = {{ wireguard_private_key_effective }}

{% for peer in wireguard_effective_peers %}
[Peer]
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.allowed_ips | join(',') }}
{% if peer.endpoint | default('') | string | trim | length > 0 %}
Endpoint = {{ peer.endpoint }}:{{ peer.listen_port }}
{% endif %}
{% if peer.endpoint | default('') | string | trim | length > 0 and (peer.persistent_keepalive | default(0) | int) > 0 %}
PersistentKeepalive = {{ peer.persistent_keepalive }}
{% endif %}
{% endfor %}
